  font-weight: 600;
}

.area-cta {
  font-weight: 600;
  color: var(--brand);
  font-size: 0.95rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

/* ── BOTTOM CTA ── */
.bottom-cta {
  background: var(--white);
  border-top: 1px solid var(--border);
  text-align: center;
  padding: 6rem 2rem;
}
.bottom-cta-content {
  max-width: 600px;
  margin: 0 auto;
}
.bottom-cta h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 700;
  margin-bottom: 1rem;
}
.bottom-cta p {
  font-size: 1.1rem;
  color: var(--text-muted);
  margin-bottom: 2.5rem;
}

/* ── FOOTER ── */
footer {
  background: var(--white);
  border-top: 1px solid var(--border);
  padding: 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text-main);
}
.footer-brand em { color: var(--brand); font-style: italic; }
.footer-copy {
  font-size: 0.85rem;
  color: var(--text-muted);
}

/* ── ANIMATIONS ── */
@keyframes riseIn {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
.reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
}
.reveal.visible { opacity: 1; transform: translateY(0); }
</style>
</head>
<body>

<nav id="nav">
