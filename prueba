<style>
:root {
  /* Nueva paleta luminosa y confiable */
  --ink:    #ffffff;
  --panel:  #f8fafc;
  --card:   #ffffff;
  --border: #e2e8f0;
  --brand:  #2563eb; /* Azul ciudadano */
  --brand-light: #eff6ff;
  --brand-dark: #1d4ed8;
  --text-main: #1e293b;
  --text-muted: #64748b;
  --white:  #ffffff;
  --shadow: rgba(15, 23, 42, 0.08);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--panel);
  color: var(--text-main);
  font-family: 'DM Sans', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── NAV ── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 2.5rem;
  transition: background 0.4s, backdrop-filter 0.4s, border-color 0.4s;
  border-bottom: 1px solid transparent;
}
nav.scrolled {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(14px);
  border-color: var(--border);
  box-shadow: 0 4px 20px rgba(0,0,0,0.02);
}
.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-main);
  text-decoration: none;
  letter-spacing: -0.01em;
}
.nav-logo em { color: var(--brand); font-style: italic; }
.nav-links {
  display: flex;
  gap: 2rem;
  align-items: center;
}
.nav-links a {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--brand); }
.nav-links .nav-cta {
  color: var(--brand);
  background: var(--brand-light);
  border-radius: 6px;
  padding: 0.5rem 1.1rem;
  transition: background 0.25s, color 0.25s;
}
.nav-links .nav-cta:hover { background: var(--brand); color: var(--white); }

@media (max-width: 600px) {
  nav { padding: 1rem 1.25rem; }
  .nav-links { gap: 1rem; }
  .nav-links a:not(.nav-cta) { display: none; }
}

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rem 2rem 5rem;
  overflow: hidden;
  background: radial-gradient(circle at top, #ffffff 0%, var(--panel) 100%);
}

/* Animated orbs (Adaptados a tonos claros) */
.orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(80px);
  opacity: 0.4;
  animation: orbFloat linear infinite;
}
.orb-1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(37,99,235,0.1) 0%, transparent 70%);
  top: -100px; left: -100px;
  animation-duration: 22s;
}
.orb-2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(14,165,233,0.1) 0%, transparent 70%);
  top: 30%; right: -80px;
  animation-duration: 18s;
  animation-delay: -6s;
}

@keyframes orbFloat {
  0%   { transform: translate(0px, 0px) scale(1); }
  25%  { transform: translate(20px, -15px) scale(1.03); }
  50%  { transform: translate(5px, 20px) scale(0.97); }
  75%  { transform: translate(-18px, 8px) scale(1.02); }
  100% { transform: translate(0px, 0px) scale(1); }
}

/* Canvas for particles */
#hero-canvas {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.6;
}

/* Content */
.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0;
  width: 100%;
  max-width: 700px;
}

.hero-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3rem, 9vw, 5.5rem);
  font-weight: 700;
  line-height: 0.92;
  color: var(--text-main);
  letter-spacing: -0.02em;
  opacity: 0;
  animation: riseIn 1s cubic-bezier(.22,1,.36,1) forwards 0.2s;
  margin-bottom: 0.5rem;
}
.hero-logo .accent {
  color: var(--brand);
  font-style: italic;
}

.hero-tagline {
  font-size: clamp(1.2rem, 2.5vw, 1.8rem);
  font-weight: 500;
  color: var(--text-main);
  opacity: 0;
  animation: riseIn 1s cubic-bezier(.22,1,.36,1) forwards 0.4s;
  margin-bottom: 1.5rem;
}

.hero-rule {
  width: 40px;
  height: 4px;
  background: var(--brand);
  border-radius: 2px;
  opacity: 0;
  animation: riseIn 0.8s ease forwards 0.5s;
  margin-bottom: 1.5rem;
}

.hero-desc {
  font-size: 1.1rem;
  color: var(--text-muted);
  font-weight: 400;
  line-height: 1.6;
  opacity: 0;
  animation: riseIn 1s cubic-bezier(.22,1,.36,1) forwards 0.6s;
  margin-bottom: 2.5rem;
}

/* Buscador Principal */
.search-container {
  width: 100%;
  max-width: 550px;
  opacity: 0;
  animation: riseIn 1s cubic-bezier(.22,1,.36,1) forwards 0.7s;
  margin-bottom: 2rem;
  position: relative;
}
.search-input {
  width: 100%;
  padding: 1.2rem 1.5rem 1.2rem 3rem;
  font-size: 1.05rem;
  font-family: 'DM Sans', sans-serif;
  color: var(--text-main);
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 50px;
  box-shadow: 0 10px 25px var(--shadow);
  transition: all 0.3s ease;
  outline: none;
}
.search-input:focus {
  border-color: var(--brand);
  box-shadow: 0 10px 30px rgba(37,99,235,0.15);
}
.search-icon {
  position: absolute;
  left: 1.2rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
}

/* CTA group */
.cta-group {
  opacity: 0;
  animation: riseIn 1s cubic-bezier(.22,1,.36,1) forwards 0.8s;
  margin-bottom: 4rem;
}

.cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  background: var(--brand);
  color: var(--white);
  font-size: 1rem;
  text-decoration: none;
  padding: 1rem 2.2rem;
  font-weight: 600;
  border-radius: 50px;
  transition: background 0.3s ease, transform 0.2s;
  box-shadow: 0 4px 15px rgba(37,99,235,0.3);
}
.cta-primary:hover { 
  background: var(--brand-dark); 
  transform: translateY(-2px);
}
.cta-primary svg { transition: transform 0.3s; }
.cta-primary:hover svg { transform: translateX(4px); }

/* Momentos Vitales */
.vital-moments {
  display: flex;
  gap: 1.5rem;
  opacity: 0;
  animation: riseIn 1s cubic-bezier(.22,1,.36,1) forwards 1s;
  flex-wrap: wrap;
  justify-content: center;
}
.moment-badge {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--white);
  border: 1px solid var(--border);
  padding: 0.6rem 1.2rem;
  border-radius: 30px;
  font-weight: 500;
  font-size: 0.95rem;
  color: var(--text-main);
  box-shadow: 0 2px 10px var(--shadow);
  cursor: default;
  transition: transform 0.2s, border-color 0.2s;
}
.moment-badge:hover {
  transform: translateY(-2px);
  border-color: var(--brand);
}

/* ── AREAS GRID (PROBLEMAS REALES) ── */
.section-areas {
  position: relative;
  z-index: 1;
  max-width: 1000px;
  margin: 0 auto;
  padding: 5rem 2rem 7rem;
}
.areas-header {
  text-align: center;
  margin-bottom: 4rem;
}
.areas-header h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.2rem, 4vw, 3rem);
  font-weight: 700;
  color: var(--text-main);
}
.areas-header h2 .accent { color: var(--brand); font-style: italic; }

.areas-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem;
}
@media (max-width: 768px) {
  .areas-grid { grid-template-columns: 1fr; }
}

.area-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2.5rem 2rem;
  text-decoration: none;
  box-shadow: 0 4px 20px var(--shadow);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  display: flex;
  flex-direction: column;
}
.area-card:hover { 
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12); 
  border-color: var(--brand-light);
}

.area-header-wrap {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.area-icon { 
  font-size: 2rem; 
  background: var(--panel);
  padding: 0.8rem;
  border-radius: 12px;
}
.area-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.1;
}

.area-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-bottom: 2rem;
  flex-grow: 1;
}
.area-list li {
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.5;
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
}
.area-list li::before {
  content: '→';
  color: var(--brand);
  font-weight: bold;
}
.area-list li strong {
