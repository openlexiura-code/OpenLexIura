<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tema 8 — Defraudaciones | Derecho Penal Económico</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,400&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #13161d;
    --card: #1a1e28;
    --border: #252a38;
    --red: #e63946;
    --red-dim: #9b1b26;
    --gold: #f4a261;
    --gold-dim: #a0622e;
    --teal: #2ec4b6;
    --teal-dim: #1a7a72;
    --blue: #4895ef;
    --blue-dim: #1f4f8f;
    --purple: #9b59b6;
    --text: #e8eaf0;
    --text-muted: #8892a4;
    --text-dim: #5a6478;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 17px;
    line-height: 1.7;
  }

  /* ── HEADER ── */
  .site-header {
    background: linear-gradient(135deg, #0d0f14 0%, #1a0a10 50%, #0d1520 100%);
    border-bottom: 2px solid var(--red);
    padding: 60px 40px 50px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .site-header::before {
    content: '⚖';
    position: absolute;
    font-size: 320px;
    opacity: 0.04;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }
  .site-header .badge {
    display: inline-block;
    background: var(--red);
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    padding: 4px 14px;
    border-radius: 2px;
    margin-bottom: 20px;
    text-transform: uppercase;
  }
  .site-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -1px;
    color: #fff;
  }
  .site-header h1 span { color: var(--red); }
  .site-header p {
    margin-top: 16px;
    color: var(--text-muted);
    font-size: 15px;
    font-style: italic;
    letter-spacing: 0.5px;
  }

  /* ── NAV ── */
  .toc {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 20px 40px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .toc a {
    color: var(--text-muted);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    padding: 6px 14px;
    border: 1px solid var(--border);
    border-radius: 20px;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .toc a:hover { color: #fff; border-color: var(--red); background: rgba(230,57,70,.12); }

  /* ── CONTAINER ── */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 30px; }

  /* ── SECTIONS ── */
  .section {
    padding: 70px 0 60px;
    border-bottom: 1px solid var(--border);
  }
  .section:last-child { border-bottom: none; }

  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 32px;
    color: #fff;
  }

  /* ── HERO CARD (with image) ── */
  .hero-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    margin-bottom: 36px;
  }
  .hero-card .hc-img {
    min-height: 300px;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .hero-card .hc-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 60%, var(--card));
  }
  .hero-card .hc-body {
    background: var(--card);
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-card .hc-body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 14px;
  }
  .hero-card .hc-body p {
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.7;
  }
  @media(max-width:700px) { .hero-card { grid-template-columns: 1fr; } }

  /* ── FLOW CHAIN ── */
  .flow-chain {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 36px 0;
    flex-wrap: wrap;
  }
  .flow-step {
    flex: 1;
    min-width: 160px;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 24px 20px;
    text-align: center;
    position: relative;
  }
  .flow-step:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -15px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 22px;
    color: var(--red);
    z-index: 2;
  }
  .flow-step .fs-icon { font-size: 36px; margin-bottom: 10px; display: block; }
  .flow-step .fs-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .flow-step .fs-title { font-weight: 600; color: #fff; font-size: 15px; }
  .flow-step .fs-desc { font-size: 13px; color: var(--text-muted); margin-top: 6px; }

  /* ── IMAGE GRID ── */
  .img-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin: 36px 0;
  }
  .img-card {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card);
  }
  .img-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .img-card .ic-body { padding: 20px; }
  .img-card .ic-body h4 { color: #fff; font-size: 15px; font-weight: 600; margin-bottom: 6px; }
  .img-card .ic-body p { color: var(--text-muted); font-size: 13px; line-height: 1.6; }

  /* ── LAW BLOCK ── */
  .law-block {
    background: linear-gradient(135deg, #0f1520, #131a2a);
    border-left: 4px solid var(--blue);
    border-radius: 0 10px 10px 0;
    padding: 24px 28px;
    margin: 24px 0;
    position: relative;
  }
  .law-block .lb-art {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--blue);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .law-block p { color: var(--text); font-size: 15px; font-style: italic; line-height: 1.75; }
  .law-block strong { color: var(--gold); font-style: normal; }

  /* ── PENALTY BOX ── */
  .penalty-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin: 28px 0;
  }
  .penalty-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 22px;
    text-align: center;
  }
  .penalty-card .pc-num {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 900;
    display: block;
    margin-bottom: 4px;
  }
  .penalty-card .pc-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
  .penalty-card .pc-detail { font-size: 14px; color: var(--text); margin-top: 10px; line-height: 1.5; }
  .pc-red .pc-num { color: var(--red); }
  .pc-gold .pc-num { color: var(--gold); }
  .pc-teal .pc-num { color: var(--teal); }
  .pc-blue .pc-num { color: var(--blue); }

  /* ── CALLOUT ── */
  .callout {
    background: rgba(230,57,70,0.08);
    border: 1px solid rgba(230,57,70,0.3);
    border-radius: 10px;
    padding: 22px 26px;
    margin: 24px 0;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .callout .co-icon { font-size: 28px; flex-shrink: 0; }
  .callout .co-text h4 { color: var(--red); font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
  .callout .co-text p { font-size: 14px; color: var(--text-muted); line-height: 1.65; }
  .callout.gold { background: rgba(244,162,97,0.08); border-color: rgba(244,162,97,0.3); }
  .callout.gold .co-text h4 { color: var(--gold); }
  .callout.teal { background: rgba(46,196,182,0.08); border-color: rgba(46,196,182,0.3); }
  .callout.teal .co-text h4 { color: var(--teal); }

  /* ── QUOTE ── */
  .jurisprudencia {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 28px 32px;
    margin: 28px 0;
    position: relative;
  }
  .jurisprudencia::before {
    content: '❝';
    font-size: 60px;
    color: var(--red-dim);
    position: absolute;
    top: 10px;
    left: 20px;
    line-height: 1;
    opacity: 0.5;
  }
  .jurisprudencia blockquote {
    font-style: italic;
    font-size: 15px;
    line-height: 1.8;
    color: var(--text);
    padding-left: 30px;
    margin-bottom: 14px;
  }
  .jurisprudencia cite {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--red);
    letter-spacing: 1px;
    padding-left: 30px;
    display: block;
  }

  /* ── CONCURSO DIAGRAM ── */
  .concurso-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 28px 0;
  }
  .concurso-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
  }
  .concurso-card h4 {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    color: #fff;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .concurso-card p { font-size: 14px; color: var(--text-muted); line-height: 1.65; }
  .concurso-card .verdict {
    margin-top: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    padding: 6px 12px;
    border-radius: 4px;
    display: inline-block;
  }
  .verdict-dual { background: rgba(230,57,70,0.15); color: var(--red); }
  .verdict-solo { background: rgba(46,196,182,0.15); color: var(--teal); }

  /* ── TAGS ── */
  .tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin: 20px 0; }
  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 5px 12px;
    border-radius: 4px;
    letter-spacing: 0.5px;
    border: 1px solid;
  }
  .tag-r { background: rgba(230,57,70,.1); color: var(--red); border-color: rgba(230,57,70,.3); }
  .tag-g { background: rgba(244,162,97,.1); color: var(--gold); border-color: rgba(244,162,97,.3); }
  .tag-t { background: rgba(46,196,182,.1); color: var(--teal); border-color: rgba(46,196,182,.3); }
  .tag-b { background: rgba(72,149,239,.1); color: var(--blue); border-color: rgba(72,149,239,.3); }

  /* ── IMAGE FULL WIDTH ── */
  .img-full {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 10px;
    margin: 28px 0;
    border: 1px solid var(--border);
  }

  /* ── SPLIT ── */
  .split-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin: 28px 0;
    align-items: start;
  }
  @media(max-width:700px) { .split-2, .concurso-grid { grid-template-columns: 1fr; } }

  /* ── LIST STYLED ── */
  .styled-list { list-style: none; margin: 16px 0; }
  .styled-list li {
    padding: 10px 0 10px 28px;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
    color: var(--text);
    position: relative;
  }
  .styled-list li:last-child { border-bottom: none; }
  .styled-list li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--red);
    font-size: 10px;
    top: 14px;
  }
  .styled-list li strong { color: var(--gold); }

  /* ── SCROLL PROGRESS ── */
  #progress { position: fixed; top: 0; left: 0; height: 3px; background: var(--red); z-index: 9999; width: 0%; transition: width 0.1s; }

  /* ── HIGHLIGHT BUBBLE ── */
  .bubble {
    display: inline-block;
    background: rgba(230,57,70,0.15);
    border: 1px solid rgba(230,57,70,0.4);
    color: var(--red);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'JetBrains Mono', monospace;
  }

  /* img-text-side */
  .side-img {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 28px;
    align-items: start;
    margin: 28px 0;
  }
  .side-img img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid var(--border);
  }
  @media(max-width:700px) { .side-img { grid-template-columns: 1fr; } }

  /* ── FOOTER ── */
  footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 30px;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
  }
</style>
</head>
